PORT=3000

# PostgreSQL
# Opción A — Docker (docker compose up -d): puerto 5433, user/pass postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/asistencia_institucional_db

# Opción B — PostgreSQL local (DBeaver/pgAdmin): cambiá user, password y puerto
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/asistencia_institucional_db

# Redis
# Opción A — Docker
REDIS_URL=redis://localhost:6379

# TTL en segundos
CACHE_TTL_ASISTENCIA=120
CACHE_TTL_USUARIO=300
